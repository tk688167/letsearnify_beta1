generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                   @id @default(cuid())
  memberId                String                   @unique @default(cuid())
  name                    String?
  email                   String?                  @unique
  phoneNumber             String?
  emailVerified           DateTime?
  password                String?
  image                   String?
  role                    String                   @default("USER")
  balance                 Float                    @default(0.0)
  tier                    Tier                     @default(NEWBIE)
  tierStatus              TierStatus               @default(CURRENT)
  arnBalance              Float                    @default(0.0)
  lockedArnBalance        Float                    @default(0.0)
  referralCode            String?                  @unique
  referredByCode          String?
  isActiveMember          Boolean                  @default(false)
  isCbspMember            Boolean                  @default(false)
  activeMembers           Int                      @default(0)
  totalDeposit            Float                    @default(0.0)
  mudarabahBalance        Float                    @default(0.0)
  dailyEarningWallet      Float                    @default(0.0)
  kycStatus               String                   @default("NOT_VERIFIED")
  kycDocument             String?
  securityQuestion        String?
  securityAnswer          String?
  spendingLimit           Float?
  currency                String                   @default("USD")
  language                String                   @default("en")
  country                 String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  lastWithdrawalTime      DateTime?
  lastSpinTime            DateTime?
  dailySpinCount          Int                      @default(0)
  premiumBonusSpins       Int                      @default(0)
  lastPremiumSpinTime     DateTime?
  lastSurpriseDate        DateTime?
  lastUnlockAt            DateTime?
  unlockAt                DateTime?
  unlockExpiry            DateTime?
  lastActivityAt          DateTime                 @default(now())
  lastLoginAt             DateTime?
  lockedBalance           Float                    @default(0.0)
  accounts                Account[]
  adminLogs               AdminLog[]               @relation("AdminTarget")
  cbspContributions       CbspContribution[]
  dailyEarningInvestments DailyEarningInvestment[]
  emailVerificationTokens EmailVerificationToken[]
  investments             Investment[]
  mlmLogs                 MLMLog[]
  merchantTransactions    MerchantTransaction[]
  mudarabahInvestments    MudarabahInvestment[]
  passwordResetToken      PasswordResetToken?
  paymentMethods          PaymentMethod[]
  postbackLogs            PostbackLog[]
  referralCommissions     ReferralCommission[]     @relation("CommissionEarner")
  referralsMade           ReferralCommission[]     @relation("CommissionSource")
  referralTree            ReferralTree?
  royaltyContributions    RoyaltyContribution[]
  sessions                Session[]
  tasks                   TaskCompletion[]
  transactions            Transaction[]
  unlockActivations       UnlockActivation[]
  referrer                User?                    @relation("ReferralTree", fields: [referredByCode], references: [referralCode])
  referrals               User[]                   @relation("ReferralTree")
  visits                  Visit[]
  wallets                 Wallet?

  @@index([email])
  @@index([referralCode])
}

model UnlockActivation {
  id              String   @id @default(cuid())
  userId          String
  amount          Float    @default(1.0)
  achievementPool Float
  referrals       Float
  cbsp            Float    @default(0.0)
  royalty         Float    @default(0.0)
  company         Float
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SpinReward {
  id          String   @id @default(cuid())
  label       String
  value       Float
  type        String
  probability Float
  color       String
  textColor   String?
  isEnabled   Boolean  @default(true)
  spinType    String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CbspContribution {
  id                 String   @id @default(cuid())
  userId             String
  depositAmount      Float
  contributionAmount Float
  description        String?
  createdAt          DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RoyaltyContribution {
  id                 String   @id @default(cuid())
  userId             String
  depositAmount      Float
  contributionAmount Float
  createdAt          DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PaymentMethod {
  id        String   @id @default(cuid())
  userId    String
  title     String
  type      String
  details   String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Distribution {
  id         String   @id @default(cuid())
  poolName   String?
  poolId     String?
  amount     Float
  percentage Float
  recipients Int
  tierRates  Json?
  createdAt  DateTime @default(now())
  pool       Pool?    @relation(fields: [poolId], references: [id])
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model PostbackLog {
  id        String   @id @default(cuid())
  network   String
  url       String?
  params    Json?
  userId    String?
  status    String
  error     String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Visit {
  id               String   @id @default(cuid())
  sessionId        String?
  userId           String?
  ip               String?
  country          String?
  city             String?
  device           String?
  os               String?
  browser          String?
  userAgent        String?
  path             String
  referrer         String?
  screenResolution String?
  language         String?
  duration         Int?
  createdAt        DateTime @default(now())
  user             User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([sessionId])
}

model Transaction {
  id                 String   @id @default(cuid())
  userId             String
  amount             Float
  type               String
  status             String
  method             String?
  description        String?
  arnMinted          Float    @default(0.0)
  txId               String?  @unique
  destinationAddress String?
  createdAt          DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([txId])
  @@index([type])
}

model Investment {
  id        String   @id @default(cuid())
  userId    String
  poolName  String
  amount    Float
  roi       Float
  status    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Task {
  id          String           @id @default(cuid())
  title       String
  description String
  reward      Float
  type        String
  status      String
  link        String?
  imageUrl    String?
  createdAt   DateTime         @default(now())
  companyId   String?
  company     Company?         @relation(fields: [companyId], references: [id])
  completions TaskCompletion[]
}

model Company {
  id        String   @id @default(cuid())
  name      String   @unique
  logoUrl   String?
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]
}

model TaskCompletion {
  id           String   @id @default(cuid())
  userId       String
  taskId       String
  status       String
  proof        String?
  remarks      String?
  pointsEarned Float    @default(0.0)
  createdAt    DateTime @default(now())
  task         Task     @relation(fields: [taskId], references: [id])
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Gig {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  sellerId    String
  image       String?
  category    String
  rating      Float    @default(5.0)
  reviews     Int      @default(0)
  createdAt   DateTime @default(now())
}

model PlatformWallet {
  id         String   @id @default(cuid())
  network    String   @unique
  address    String
  qrCodePath String   @default("/qr-placeholder.png")
  updatedAt  DateTime @updatedAt
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  network   String
  address   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReferralCommission {
  id           String   @id @default(cuid())
  earnerId     String
  sourceUserId String
  amount       Float
  level        Int
  percentage   Float
  createdAt    DateTime @default(now())
  earner       User     @relation("CommissionEarner", fields: [earnerId], references: [id], onDelete: Cascade)
  sourceUser   User     @relation("CommissionSource", fields: [sourceUserId], references: [id], onDelete: Cascade)
}

model AdminLog {
  id           String   @id @default(cuid())
  adminId      String
  targetUserId String?
  actionType   String
  details      String
  createdAt    DateTime @default(now())
  targetUser   User?    @relation("AdminTarget", fields: [targetUserId], references: [id])
}

model ReferralTree {
  id           String   @id @default(cuid())
  userId       String   @unique
  advisorId    String?
  supervisorId String?
  managerId    String?
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MLMLog {
  id          String   @id @default(cuid())
  userId      String
  type        String
  amount      Float
  description String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Pool {
  id                  String         @id @default(cuid())
  name                String         @unique
  balance             Float          @default(0.0)
  percentage          Float          @default(0.0)
  description         String?
  updatedAt           DateTime       @updatedAt
  distributionHistory Distribution[]
}

model MerchantCountry {
  id                    String                  @id @default(cuid())
  name                  String                  @unique
  code                  String
  status                String                  @default("COMING_SOON")
  currency              String                  @default("USD")
  description           String?
  instruction           String?
  withdrawalDescription String?
  withdrawalInstruction String?
  exchangeRate          Float                   @default(1.0)
  serviceFee            Float                   @default(0.0)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  contacts              MerchantContact[]
  methods               MerchantPaymentMethod[]
}

model MerchantPaymentMethod {
  id            String          @id @default(cuid())
  countryId     String
  name          String
  accountNumber String?
  accountName   String?
  iban          String?
  instructions  String?
  country       MerchantCountry @relation(fields: [countryId], references: [id], onDelete: Cascade)
}

model MerchantContact {
  id        String          @id @default(cuid())
  countryId String
  name      String
  phone     String
  country   MerchantCountry @relation(fields: [countryId], references: [id], onDelete: Cascade)
}

model MerchantTransaction {
  id              String   @id @default(cuid())
  userId          String
  countryCode     String
  paymentMethodId String
  type            String
  amount          Float
  currency        String?
  convertedAmount Float?
  exchangeRate    Float?
  screenshot      String?
  accountNumber   String?
  accountName     String?
  note            String?
  status          String   @default("PENDING")
  adminNotes      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TierConfiguration {
  id          String   @id @default(cuid())
  tier        String   @unique
  requiredArn Float    @default(0.0)
  members     Int
  levels      Json
  updatedAt   DateTime @updatedAt
}

model SocialProofSettings {
  id             String   @id @default(cuid())
  totalUsers     Int      @default(12540)
  totalDeposited Float    @default(850000.00)
  totalPayouts   Float    @default(320000.00)
  activeOnline   Int      @default(345)
  updatedAt      DateTime @updatedAt
}

model PayoutProof {
  id        String   @id @default(cuid())
  imageUrl  String
  amount    Float
  userName  String
  method    String
  date      DateTime @default(now())
  createdAt DateTime @default(now())
}

model Network {
  id             String   @id @default(cuid())
  name           String   @unique
  slug           String   @unique
  type           String
  apiKey         String?
  secretKey      String?
  postbackSecret String?
  isEnabled      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MudarabahPool {
  id             String                  @id @default(cuid())
  title          String
  description    String?
  imageUrl       String?
  targetAmount   Float
  minDeposit     Float                   @default(1.0)
  maxDeposit     Float
  durationMonths Int
  isLive         Boolean                 @default(false)
  totalDeposited Float                   @default(0.0)
  status         String                  @default("OPEN")
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  distributions  MudarabahDistribution[]
  investments    MudarabahInvestment[]
}

model MudarabahInvestment {
  id           String        @id @default(cuid())
  userId       String
  poolId       String
  amount       Float
  status       String        @default("ACTIVE")
  profitEarned Float         @default(0.0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  pool         MudarabahPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([poolId])
}

model MudarabahDistribution {
  id                      String        @id @default(cuid())
  poolId                  String
  totalProfit             Float
  userSharePercentage     Float
  platformSharePercentage Float
  createdAt               DateTime      @default(now())
  pool                    MudarabahPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
}

model DailyEarningInvestment {
  id                 String   @id @default(cuid())
  userId             String
  amount             Float
  status             String   @default("ACTIVE")
  profitEarned       Float    @default(0.0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  lastCalculatedDate DateTime @default(now())
  expiresAt          DateTime
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model AdminNotification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  metadata  String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum Tier {
  NEWBIE
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
  EMERALD
}

enum TierStatus {
  CURRENT
  UPGRADED
}
